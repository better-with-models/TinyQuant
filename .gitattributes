# --------------------------------------------------------------------------
# Line endings — normalise to LF in the repo, native on checkout
# --------------------------------------------------------------------------
* text=auto

# Force LF for files that must be consistent across platforms
*.py text eol=lf
*.pyi text eol=lf
*.md text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.txt text eol=lf
*.rst text eol=lf
*.sh text eol=lf
*.bat text eol=crlf

# --------------------------------------------------------------------------
# Binary files — do not diff or merge
# --------------------------------------------------------------------------
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.whl binary
*.tar.gz binary
*.zip binary

# Store generated binary brand assets in LFS
docs/assets/*.png filter=lfs diff=lfs merge=lfs -text

# Store rotation-matrix fixture snapshots in LFS (raw f64 binary blobs
# up to several MiB per entry). Regenerate via
# `cargo xtask fixtures refresh-rotation`.
rust/crates/tinyquant-core/tests/fixtures/rotation/*.bin filter=lfs diff=lfs merge=lfs -text

# Store codebook training + trained-entry fixture snapshots in LFS
# (training corpus is ~2.5 MiB of f32). Regenerate via
# `cargo xtask fixtures refresh-codebook`.
rust/crates/tinyquant-core/tests/fixtures/codebook/*.bin filter=lfs diff=lfs merge=lfs -text

# Store quantize parity fixture snapshots in LFS. Regenerate via
# `cargo xtask fixtures refresh-quantize`.
rust/crates/tinyquant-core/tests/fixtures/quantize/*.bin filter=lfs diff=lfs merge=lfs -text

# Store residual parity fixture snapshots in LFS. Regenerate via
# `cargo xtask fixtures refresh-residual`.
rust/crates/tinyquant-core/tests/fixtures/residual/*.bin filter=lfs diff=lfs merge=lfs -text

# Store end-to-end codec byte-parity fixture snapshots in LFS. Regenerate via
# `cargo xtask fixtures refresh-codec`.
rust/crates/tinyquant-core/tests/fixtures/codec/*.bin filter=lfs diff=lfs merge=lfs -text

# --------------------------------------------------------------------------
# Git diff drivers — improve diffs for common formats
# --------------------------------------------------------------------------
*.py diff=python

# --------------------------------------------------------------------------
# Linguist overrides — keep GitHub language stats accurate
# --------------------------------------------------------------------------
docs/** linguist-documentation
tests/** linguist-detectable=false
